# ============================================================
# Server Environment Variables — Example
# ============================================================
# Copy this file to .env and fill in your values for local dev.
# For Render deployment, see .env.render
# ============================================================

# Server port (Render uses 10000; local dev uses 5000)
PORT=5000

# Client URL for CORS — your frontend URL (no trailing slash)
CLIENT_URL=http://localhost:5173

# Admin Panel Credentials
ADMIN_USERNAME=k-admin
ADMIN_PASSWORD=Kishan-admin@2004

# Session secret — use a long random string
SESSION_SECRET=your-long-random-secret-key-here

# SMTP Configuration (required for contact form & admin alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Email recipient for contact form submissions & security alerts
CONTACT_EMAIL=your-email@gmail.com
